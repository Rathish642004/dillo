{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/marketing-website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Archivo Black|JetBrains Mono|Public Sans|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Archivo Black, JetBrains Mono, Public Sans, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|banner|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, banner."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:red|navy|neutral|success|warning)$/]",
        "message": "<Badge> variant must be one of 'red' | 'navy' | 'neutral' | 'success' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|block|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, block."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|navy|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'navy' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:pad|variant|interactive|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: pad, variant, interactive."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:sm|md|lg|none)$/]",
        "message": "<Card> pad must be one of 'sm' | 'md' | 'lg' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|raised|outline|navy)$/]",
        "message": "<Card> variant must be one of 'default' | 'raised' | 'outline' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:onNavigate|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|navy)$/]",
        "message": "<IconButton> variant must be one of 'primary' | 'secondary' | 'ghost' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|iconLeft|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, iconLeft."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onNavigate|onCta|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: active, onNavigate, onCta."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:home|about|products|portfolio|contact)$/]",
        "message": "<NavBar> active must be one of 'home' | 'about' | 'products' | 'portfolio' | 'contact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|description|icon|key|ref|className|style|children)$/]",
        "message": "<ProcessStep> doesn't accept that prop. Declared props: number, title, description, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|imageSrc|items|ctaLabel|onCta|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: title, description, imageSrc, items, ctaLabel, onCta."
      },
      {
        "selector": "JSXOpeningElement[name.name='Section'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|pad|bottomRule|key|ref|className|style|children)$/]",
        "message": "<Section> doesn't accept that prop. Declared props: tone, pad, bottomRule."
      },
      {
        "selector": "JSXOpeningElement[name.name='Section'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:white|alt|navy|red)$/]",
        "message": "<Section> tone must be one of 'white' | 'alt' | 'navy' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Section'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Section> pad must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|align|onDark|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, title, description, align, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|options|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, hint, error, options."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|onDark|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, label, icon, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|author|role|avatarSrc|key|ref|className|style|children)$/]",
        "message": "<TestimonialCard> doesn't accept that prop. Declared props: quote, author, role, avatarSrc."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhatsAppFab'] > JSXAttribute > JSXIdentifier[name!=/^(?:phone|message|key|ref|className|style|children)$/]",
        "message": "<WhatsAppFab> doesn't accept that prop. Declared props: phone, message."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
